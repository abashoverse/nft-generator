# Optional: enable Umami analytics by setting BOTH variables.
# When either is unset/empty, the analytics script is not injected.
# PUBLIC_UMAMI_SCRIPT_URL=https://umami.example.com/script.js
# PUBLIC_UMAMI_WEBSITE_ID=your-website-id-here

# Paywall config. If none of these are set, the paywall is OFF and the
# app is fully free (treated as a dev-style bypass). The paywall turns ON
# the moment any of NFT addresses or receiver address is set.

# Mainnet ERC-721 addresses for the free-access NFT holder check.
# Either one (or both) enables the "hold an NFT" path in the unlock modal.
# PUBLIC_ABASHO_NFT_ADDRESS=0x...
# PUBLIC_ABASHOS_NFT_ADDRESS=0x...

# Receiver wallet for the one-time payment. Enables the "pay once" path.
# PUBLIC_PAY_RECEIVER_ADDRESS=0x...

# Payment amount in USD. Converted to ETH at the current rate at pay time
# via CoinGecko. Default is 10 if unset.
# PUBLIC_PAY_AMOUNT_USD=10

# Link to the GitHub repo so users can self-host instead of paying.
# When unset, the self-host option is hidden in the unlock modal.
# PUBLIC_SELF_HOST_URL=https://github.com/abashoverse/nft-generator

# Dev-only override: force the paywall on while running `npm run dev` so you
# can test the locked UI and unlock modal without a production build. Has no
# effect in production builds.
# PUBLIC_FORCE_PAYWALL=true
